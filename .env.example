# TradingView MCP Jackson — Environment Variables
# Copy this file to .env and adjust values if needed.
# The defaults work for most setups.
#
# Usage:
#   cp .env.example .env

# ─── CDP Connection ──────────────────────────────────────────────────────────
# Host and port for the Chrome DevTools Protocol debug endpoint.
# TradingView must be launched with --remote-debugging-port matching CDP_PORT.
# Only change these if you have a non-standard setup (e.g. TradingView on a
# remote machine, or port 9222 is already in use by another app).

CDP_HOST=localhost
CDP_PORT=9222

# ─── Data Storage ────────────────────────────────────────────────────────────
# Root directory for all persistent data:
# reports, grades, analytics, datasets, models, backfill manifests.
# Tilde expansion is supported.

DATA_DIR=~/.tradingview-mcp

# ─── Report Timezone ─────────────────────────────────────────────────────────
# IANA timezone used for report timestamps and NYSE trading day scheduling.
# The default (America/New_York) is correct for NQ/ES futures and US equities.
# Change if you trade instruments on a different primary exchange.

REPORT_TIMEZONE=America/New_York

# ─── Screenshots ─────────────────────────────────────────────────────────────
# Directory where capture_screenshot saves PNG files.
# Relative paths are resolved from the project root.

SCREENSHOT_DIR=screenshots

# ─── CDP Retry Settings ──────────────────────────────────────────────────────
# How aggressively to retry failed CDP connections.
# Increase CDP_MAX_RETRIES if TradingView takes a long time to load on startup.

CDP_MAX_RETRIES=5
CDP_BASE_DELAY_MS=500
CDP_MAX_DELAY_MS=30000

# ─── Analytics ───────────────────────────────────────────────────────────────
# Minimum cohort size for best/worst condition reports.
# Cohorts with fewer than this many samples are excluded from condition reports.

ANALYTICS_MIN_COHORT_SIZE=3

# ─── Backfill ────────────────────────────────────────────────────────────────
# How often to trigger analytics + model rebuilds during a backfill run.
# Lower = more frequent rebuilds (slower), higher = fewer (faster).

BACKFILL_REBUILD_EVERY_N_DAYS=5
